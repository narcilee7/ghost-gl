{
  "name": "ghost-gl",
  "version": "0.0.0",
  "private": true,
  "description": "Architecture-first monorepo for a virtualized grid runtime focused on heavy components.",
  "license": "MIT",
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.27.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "scripts": {
    "bench:core": "pnpm --filter ghost-gl-core bench",
    "build": "turbo run build",
    "changeset": "changeset",
    "clean": "turbo run clean && rimraf .turbo node_modules",
    "dev": "turbo run dev --parallel",
    "example:basic": "tsx examples/basic-usage.ts",
    "example:scheduler": "tsx examples/materialization-scheduler.ts",
    "format": "biome check . --write",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "release:publish": "changeset publish",
    "release:version": "changeset version",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "typecheck": "turbo run typecheck",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@changesets/cli": "^2.29.7",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
